# ============================================================
# Optional: Local Streamlit Secrets (for testing Streamlit Cloud setup locally)
# ============================================================
# 
# Streamlit cũng hỗ trợ secrets.toml để test local trước khi deploy.
# 
# CÁCH SỬ DỤNG:
# 1. Tạo file: ~/.streamlit/secrets.toml (home dir)
# 2. Dán nội dung bên dưới
# 3. Chạy streamlit run app.py
# 4. Streamlit tự load secrets từ ~/.streamlit/secrets.toml
#
# VỚI .env FILE:
# - app.py cũng load .env thông qua load_dotenv()
# - Code auto-detect: Streamlit secrets → .env → environment
# - Ưu tiên: st.secrets > .env > os.getenv()
# 
# ============================================================

OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TAVILY_API_KEY = "tvly-xxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_BASE_URL = "https://openrouter.ai/api/v1"

# Optional
SEMANTIC_SCHOLAR_API_KEY = ""
OPENALEX_EMAIL = ""
