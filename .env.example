# OpenRouter (khuyên dùng - tương thích OpenAI SDK)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Hoặc dùng OpenAI gốc (bỏ 2 dòng trên, set key bên dưới)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily - bắt buộc để search web (1000 query/tháng free tại https://tavily.com)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Semantic Scholar - free academic API. Không có key cũng chạy nhưng dễ bị 429.
# Đăng ký free: https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex - free, không cần đăng ký. Để email vào "polite pool" (nhanh + ổn định hơn).
OPENALEX_EMAIL=
